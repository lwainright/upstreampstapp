// ═══════════════════════════════════════════════════════════════
// DEMO MODE INITIALIZATION
// ═══════════════════════════════════════════════════════════════

/**
 * Initialize demo PST roster
 * Returns roster with all demo members
 */
export function initializeDemoPSTRoster() {
  return {
    roster: DEMO_PST_ROSTER,
    available: getAvailableDemoPST(),
    totalMembers: DEMO_PST_ROSTER.length,
    availableCount: getAvailableDemoPST().length,
    isDemoMode: true
  };
}

