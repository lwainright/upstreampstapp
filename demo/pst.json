// ═══════════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Get all available demo PST members
 */
export function getAvailableDemoPST() {
  return DEMO_PST_ROSTER.filter(member => 
    member.availability.status === "available" && 
    member.active === true
  );
}

/**
 * Get demo PST member by ID
 */
export function getDemoPSTById(id) {
  return DEMO_PST_ROSTER.find(member => member.id === id);
}

/**
 * Get demo PST members by specialty
 */
export function getDemoPSTBySpecialty(specialty) {
  return DEMO_PST_ROSTER.filter(member => 
    member.specialties.includes(specialty) &&
    member.availability.status !== "off-duty" &&
    member.active === true
  );
}

/**
 * Get demo PST member display info
 */
export function getDemoPSTDisplay(member) {
  return {
    name: member.name,
    role: member.role,
    unit: member.unit,
    available: member.availability.status === "available",
    specialties: member.specialties.join(", "),
    bio: member.bio
  };
}

/**
 * Check if demo PST member is currently available
 */
export function isDemoPSTAvailable(memberId) {
  const member = getDemoPSTById(memberId);
  if (!member) return false;
  
  if (!member.active) return false;
  if (member.availability.status === "off-duty") return false;
  
  // Check on-call expiration
  if (member.availability.onCallUntil) {
    const onCallDate = new Date(member.availability.onCallUntil);
    if (onCallDate < new Date()) return false;
  }
  
  return true;
}

