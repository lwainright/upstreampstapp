// ═══════════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Get resources by category
 */
export function getResourcesByCategory(category) {
  return DEMO_RESOURCES
    .filter(resource => resource.category === category)
    .sort((a, b) => a.priority - b.priority);
}

/**
 * Get crisis resources (highest priority)
 */
export function getCrisisResources() {
  return DEMO_RESOURCES
    .filter(resource => resource.category === "crisis")
    .sort((a, b) => a.priority - b.priority);
}

/**
 * Get responder-specific resources
 */
export function getResponderResources() {
  return DEMO_RESOURCES
    .filter(resource => resource.category === "responder-support")
    .sort((a, b) => a.priority - b.priority);
}

/**
 * Get resources by tag
 */
export function getResourcesByTag(tag) {
  return DEMO_RESOURCES
    .filter(resource => resource.tags.includes(tag))
    .sort((a, b) => a.priority - b.priority);
}

/**
 * Get 24/7 available resources
 */
export function get24x7Resources() {
  return DEMO_RESOURCES
    .filter(resource => 
      resource.hours && resource.hours.includes("24/7")
    )
    .sort((a, b) => a.priority - b.priority);
}

/**
 * Get resources with phone numbers
 */
export function getPhoneResources() {
  return DEMO_RESOURCES
    .filter(resource => resource.phone && resource.phone !== "")
    .sort((a, b) => a.priority - b.priority);
}

/**
 * Search resources by keyword
 */
export function searchResources(keyword) {
  const search = keyword.toLowerCase();
  return DEMO_RESOURCES.filter(resource =>
    resource.label.toLowerCase().includes(search) ||
    resource.description.toLowerCase().includes(search) ||
    resource.tags.some(tag => tag.includes(search))
  );
}

/**
 * Get resource by ID
 */
export function getResourceById(id) {
  return DEMO_RESOURCES.find(resource => resource.id === id);
}

/**
 * Get grouped resources (by category)
 */
export function getGroupedResources() {
  const grouped = {};
  
  Object.values(RESOURCE_CATEGORIES).forEach(category => {
    grouped[category] = getResourcesByCategory(category);
  });
  
  return grouped;
}

// ═══════════════════════════════════════════════════════════════
// DEMO MODE INITIALIZATION
// ═══════════════════════════════════════════════════════════════

/**
 * Initialize demo resources
 */
export function initializeDemoResources() {
  return {
    resources: DEMO_RESOURCES,
    categories: RESOURCE_CATEGORIES,
    crisis: getCrisisResources(),
    responder: getResponderResources(),
    available24x7: get24x7Resources(),
    totalResources: DEMO_RESOURCES.length,
    isDemoMode: true
  };
}

