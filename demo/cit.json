// ═══════════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════

/**
 * Get demo agency configuration
 */
export function getDemoAgency() {
  return DEMO_AGENCY;
}

/**
 * Get demo CIT team
 */
export function getDemoCITTeam() {
  return DEMO_CIT_TEAM;
}

/**
 * Get available demo PST members
 */
export function getAvailableDemoPST() {
  return DEMO_PST_PROFILES.filter(member => 
    member.availability.status === "available"
  );
}

/**
 * Check if access code is demo code
 */
export function isDemoCode(code) {
  return DEMO_AGENCY.accessCodes.includes(code.toUpperCase());
}

/**
 * Initialize demo mode
 */
export function initializeDemoMode() {
  return {
    agency: DEMO_AGENCY,
    citTeam: DEMO_CIT_TEAM,
    pstMembers: DEMO_PST_PROFILES,
    isDemoMode: true
  };
}
